{
  "name": "mineradio",
  "productName": "Mineradio",
  "version": "2.1.3",
  "description": "沉浸式音乐播放器，融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "desktopName": "Mineradio.desktop",
  "license": "GPL-3.0-or-later",
  "author": "Mineradio",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "format": "prettier . --write",
    "build:linux:pacman": "electron-builder --linux pacman",
    "build:linux:rpm": "electron-builder --linux rpm",
    "build:linux:AppImage": "electron-builder --linux AppImage",
    "build:linux:deb": "electron-builder --linux deb",
    "build:linux:dir": "electron-builder --linux dir",
    "build:windows": "electron-builder --win nsis",
    "build:macos": "electron-builder --mac dmg",
    "build:windows:dir": "electron-builder --win dir",
    "build:macos:dir": "electron-builder --mac dir"
  },
  "build": {
    "publish": null,
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": true,
    "linux": {
      "icon": "build/icon.png",
      "maintainer": "MoAEIOU <me@867678.xyz>",
      "target": [
        "pacman",
        "rpm",
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    }
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "MoAEIOU",
      "repo": "Mineradio",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://ghproxy.link/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.32.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "prettier": "^3.9.5",
    "rcedit": "^5.0.2"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.7"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
