{
  "name": "Mineradio",
  "productName": "Mineradio",
  "version": "2026.2.3",
  "description": "一款以电影镜头、粒子视觉和歌词舞台为核心的沉浸式音乐播放器。",
  "author": "Mineradio",
  "license": "GPL-3.0-only",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "format": "prettier . --write",
    "build:linux:pacman": "electron-builder --linux pacman",
    "build:linux:rpm": "electron-builder --linux rpm",
    "build:linux:AppImage": "electron-builder --linux AppImage",
    "build:linux:deb": "electron-builder --linux deb",
    "build:linux:dir": "electron-builder --linux dir",
    "build:windows": "electron-builder --win nsis",
    "build:macos": "electron-builder --mac dmg",
    "build:windows:dir": "electron-builder --win dir",
    "build:macos:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "cuefield/**/*",
      "server.js",
      "*-api.js",
      "qishui-audio-decryptor/**/*",
      "dj-analyzer.js",
      "LICENSE",
      "NOTICE.md",
      "docs/THIRD_PARTY_PORTS.md",
      "package.json",
      "!desktop/wallpaper-preload.js",
      "!public/wallpaper.html",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": true,
    "linux": {
      "icon": "build/icon.png",
      "maintainer": "MoAEIOU <me@867678.xyz>",
      "target": [
        "pacman",
        "rpm",
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MoAEIOU",
        "repo": "Mineradio"
      }
    ]
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "MoAEIOU",
      "repo": "Mineradio",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://ghproxy.link/"
      ]
    }
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.32.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "prettier": "^3.9.6"
  },
  "overrides": {
    "axios": "1.18.1",
    "body-parser": "1.20.6",
    "music-metadata": "11.14.0"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  },
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72"
}
